# Domain (pointed to Caddy VM via DNS A record)
DOMAIN=chat.example.com

# VM IPs
CADDY_VM_IP=
NATS_VM_IP=
WS_VM_1_IP=
WS_VM_2_IP=
WS_VM_3_IP=

# ============================================================
# MySQL — Choose ONE option: self-hosted OR managed
# ============================================================

# --- Option A: Self-hosted MySQL (VM 6) ---
# Used by setup-mysql.sh to create the database container.
# After running setup-mysql.sh, set MYSQL_HOST to the MySQL VM's IP
# and MYSQL_USER / MYSQL_PASSWORD to match the values below.
MYSQL_VM_IP=
MYSQL_ROOT_PASSWORD=changeme_root_password
MYSQL_SELF_HOSTED_USER=wsapp
MYSQL_SELF_HOSTED_PASSWORD=changeme_app_password

# --- Option B: Managed MySQL (PlanetScale, AWS RDS, etc.) ---
# Skip setup-mysql.sh entirely and fill in the managed DB details.

# --- Connection details (used by WS servers) ---
# For self-hosted: set MYSQL_HOST to your MYSQL_VM_IP
# For managed: set MYSQL_HOST to your provider's hostname
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=wschat
MYSQL_SSL=false
